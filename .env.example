# Felixo AI Core — Variáveis de Ambiente
#
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# Nenhuma variável é obrigatória para rodar o app em modo desenvolvimento.

# ─── CLIs externas ───────────────────────────────────────────────────────────
# Diretórios extras para buscar CLIs (claude, codex, gemini, ollama).
# Separe múltiplos caminhos com : (Linux/macOS) ou ; (Windows).
# FELIXO_CLI_PATHS=

# ─── Shell ───────────────────────────────────────────────────────────────────
# Shell personalizado para execução de comandos do terminal integrado.
# Exemplos: /bin/zsh, /usr/bin/fish, pwsh
# FELIXO_SHELL=

# ─── Node.js ─────────────────────────────────────────────────────────────────
# Diretório do binário do Node.js (override para start_app.py).
# FELIXO_NODE_BIN=

# ─── Build e Release ─────────────────────────────────────────────────────────
# Branch usada como fonte para atualizações via código-fonte.
# FELIXO_PRODUCTION_BRANCH=production

# ─── Auto-update ─────────────────────────────────────────────────────────────
# Desabilitar auto-update (1 = desabilitado).
# FELIXO_DISABLE_AUTO_UPDATE=0

# Aceitar versões pre-release no auto-update (1 = aceitar).
# FELIXO_UPDATE_PRERELEASE=0

# Canal de update customizado (ex: beta, nightly).
# FELIXO_UPDATE_CHANNEL=
